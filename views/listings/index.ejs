<% layout("/layouts/boilerplate.ejs") %>

    <style>
        #filters {
            display: flex;
            align-items: center;
            scroll-behavior: smooth;
            overflow-x: auto;
            overflow-y: hidden;
        }

        #filters::-webkit-scrollbar {
            display: none;
        }

        .filters {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        .filter {
            text-align: center;
            margin-right: 2rem;
            margin-top: 2rem;
            opacity: 0.8;
            cursor: pointer;
            flex-shrink: 0;

        }

        .filter:hover {
            opacity: 1;
        }

        .filter p {
            font-size: 0.8rem;
        }

        .tax-info {
            display: none;

        }

        .tax-toggle {
            border: 1px solid black;
            border-radius: 0.8rem;
            height: 3.2rem;
            width: fit-content;
            white-space: nowrap;
            padding: 1rem;
            margin-left: 2rem;
            display: flex;
            align-items: center;
        }

        .filters-container {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
        }

        .arrow-btn {
            height: 40px;
            width: 40px;
            cursor: pointer;
            flex-shrink: 0;
            border: none;
            border-radius: 50%;
            font-size: 1.3rem;
        }

        #filters a {
            text-decoration: none !important;
            color: black !important;
        }
    </style>
    <div class="filters-container">
        <button class="arrow-btn" onclick="slideLeft()"><i class="fa-solid fa-circle-chevron-left"></i></button>
        <div id="filters">
            <a href="/listings">
                <div class="filter">
                    <div><i class="fa-solid fa-fire"></i></div>
                    <p>Trending</p>
                </div>
            </a>
            <a href="/listings?category=rooms">
                <div class="filter">
                    <div><i class="fa-solid fa-bed"></i></div>
                    <p>Rooms</p>
                </div>
            </a>
            <a href="/listings?category=iconic_cities">
                <div class="filter">
                    <div><i class="fa-solid fa-mountain-city"></i></div>
                    <p>Iconic cities</p>
                </div>
            </a>
            <a href="/listings?category=mountains">
                <div class="filter">
                    <div><i class="fa-solid fa-mountain-sun"></i></div>
                    <p>Mountains</p>
                </div>
            </a>
            <a href="/listings?category=castles">
                <div class="filter">
                    <div><i class="fa-brands fa-fort-awesome"></i></div>
                    <p>Castles</p>
                </div>
            </a>
            <a href="/listings?category=artic">
                <div class="filter">
                    <div><i class="fa-regular fa-snowflake"></i></div>
                    <p>Arctic</p>
                </div>
            </a>
            <a href="/listings?category=camping">
                <div class="filter">
                    <div><i class="fa-solid fa-campground"></i></div>
                    <p>Camping</p>
                </div>
            </a>
            <a href="/listings?category=farms">
                <div class="filter">
                    <div><i class="fa-solid fa-cow"></i></div>
                    <p>Farms</p>
                </div>
            </a>
            <a href="/listings?category=amazing_pools">
                <div class="filter">
                    <div><i class="fa-solid fa-person-swimming"></i></i></div>
                    <p>Amazing pools</p>
                </div>
            </a>

            <div class="tax-toggle">
                <div class=" form-check form-check-reverse form-switch ">
                    <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                    <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
                </div>
            </div>
        </div>
        <button class="arrow-btn" onclick="slideRight()"><i class="fa-solid fa-circle-chevron-right"></i></button>
    </div>


    <div class="header mt-3">
        <h3>All Listings</h3>
        <!-- <form method="get" action="listings/new">
            <button>Create Listing</button>
        </form> -->
    </div>

    <div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1 g-2">

        <% for(let listing of allListings){%>
            <a href="/listings/<%=listing._id%>" class="listing-links">
                <div class="card">
                    <img src="<%= listing.image.url %>" style="height: 20rem;" class="card-img-top" alt="Listing Image">
                    <div class="card-body">
                        <p class="card-text">
                            <b>
                                <%= listing.title %>
                            </b> <br>
                            ₹<%=listing.price.toLocaleString("en-IN") %> / Night
                                <i class="tax-info">+ 18% GST</i>
                        </p>
                    </div>
                </div>
            </a>
            <%}%>

    </div>

    <script>
        let taxSwitch = document.getElementById("switchCheckDefault");
        taxSwitch.addEventListener("click", () => {
            let taxInfo = document.getElementsByClassName("tax-info");
            for (info of taxInfo) {
                if (info.style.display != "inline") {
                    info.style.display = "inline"
                } else {
                    info.style.display = "none"
                }

            }

        });

        function slideLeft() {
            document.getElementById("filters").scrollLeft -= 300;
        }

        function slideRight() {
            document.getElementById("filters").scrollLeft += 300;
        }
    </script>