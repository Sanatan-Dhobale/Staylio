<% layout("/layouts/boilerplate.ejs") %>

    <div class="row mt-3">
        <div class="col-12 col-md-8 mx-auto">
            <h3>
                <%=listing.title%>
            </h3>
        </div>
        <div class="card col-12 col-md-8 mx-auto show-card">
            <img src="<%= listing.image.url %>" class="card-img-top show-image" alt="Listing_image">
            <div class="card-body">
                <p class="card-text">
                    <i>Published By <%=listing.owner.username%></i>
                </p>
                <p class="card-text">
                    <%=listing.description%>
                </p>
                <p class="card-text">₹ <%=listing.price.toLocaleString("en-IN")%></p>
                <p class="card-text">
                    <%=listing.location%>
                </p>
                <p class="card-text">
                    <%=listing.country%>
                </p>

            </div>
        </div>
        <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
            <div class="btns d-flex gap-2 justify-content-center mt-2">
                <a class="btn btn-dark add-btn edit-btn" href="/listings/<%=listing._id%>/edit">Edit</a>

                <form method="POST" action="/listings/<%=listing._id%>?_method=Delete">
                    <button class="btn btn-dark delete-btn">Delete</button>
                </form>
            </div>
            <% } %>
                <hr>

                <div class="col-12 col-md-8 mx-auto mb-3">
                   
                        <h4>Leave a review</h4>
                        <form class="needs-validation" novalidate action="/listings/<%=listing._id%>/reviews"
                            method="POST">

                            <div class="mb-2 mt-3">
                                <label class="form-label" for="rating">Rating</label>
                                <fieldset class="starability-slot">
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]"
                                        value="1" checked aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>
                            <div class="mb-3 mt-2">
                                <label class="form-label" for="comment">Comments</label>
                                <textarea required class="form-control" name="review[comment]" id="comment" cols="30"
                                    rows="6"></textarea>
                                <div class="invalid-feedback">
                                    Please add some comment for review.
                                </div>
                            </div>
                            <button class="btn btn-dark add-btn">Submit</button>
                        </form>
                        <hr>
                        

                            <% if (listing.reviews.length> 0) { %>

                                <p><b>All reviews</b></p>
                                <div class="row">


                                    <% for (let review of listing.reviews) { %>
                                        <div class="card col-12 col-md-5 mb-3 ms-md-3">
                                            <div class="card-body">
                                                <h5 class="card-title">@<%= review.author.username %>
                                                </h5>

                                                <p class="starability-result card-text"
                                                    data-rating="<%= review.rating%>">
                                                </p>

                                                <p class="card-text">
                                                    <%= review.comment%>
                                                </p>
                                            </div>
                                            <br>
                                            <form
                                                action="/listings/<%= listing._id%>/reviews/<%= review._id%>?_method=DELETE"
                                                method="POST">
                                                <button class="btn btn-sm btn-dark">Delete</button>
                                            </form>
                                        </div>

                                        <% } %>

                                </div>
                                <% } %>

                                    <div>
                                        <h3>Where you'll be</h3>
                                        <div id="map">

                                        </div>
                                    </div>

                </div>

    </div>

    <script>
        const coordinates = '<%- JSON.stringify(listing.geometry.coordinates) %>';
        window.coordinates = JSON.parse(coordinates);

        window.mapToken = "<%= mapToken %>";
    </script>


    <script src="/js/map.js"></script>